#include <stdio.h>
#include <time.h>
#include <stdlib.h>

void imprimir_vetor(int* vet){
    int i = 0;
    for(i=0;i<10;i++){
        printf("%d ", vet[i]);
    }
    printf("\n");

}

void percorrer_vetor(int *p1, int *p2){
    int i=0, j=9;
    while(j>i){
        printf("inicio: %d | fim: %d\n", p1[i], p2[j]);
        i++;
        j--;
    }
}

int main(){
    int v[10];
    int *ptr1,*ptr2;
    srand(time(NULL));
    for (int i = 0; i < 10; i++) {
        v[i] = rand();
    }
    imprimir_vetor(v);
    ptr1 = &v[0];
    ptr2 = &v[0];
    percorrer_vetor(ptr1,ptr2);
    return 0;
}