#include <stdio.h>

void calc_circulo(float r, float * circunferencia, float * area){
    float pi = 3.14159265;
    *circunferencia = r * pi * 2;
    *area = pi * r * r  ;
}

int main(void) {
    float r, c, a;
    float* circ, * area;
    circ = &c;
    area = &a;
    scanf(" %f", &r);
    calc_circulo(r, circ, area);
    printf("circunferencia = %.2f\n", c);
    printf("area = %.2f\n", a);
    return 0;
}
