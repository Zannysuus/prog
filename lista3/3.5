#include <stdio.h>

float max_vet (int n, float* vet){
    int i, max = 0;
    for(i=0;i<=n;i++){
            if(vet[i] > max){
                max = vet[i];
            }
    }
    return max;
}

int main(void) {
    int maior, tam;
    float vet[] = {1,2,3,4,5};
    tam = sizeof(vet)/sizeof(vet[0]);
    maior = max_vet(tam, vet);
    printf("%d", maior);
    return 0;
}
