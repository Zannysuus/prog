#include <stdio.h>

float variancia(float* vet, int tam){
    int i;
    float varia = 0;
    for(i=0;i<tam-1;i++){
        varia += ((vet[i] - vet[i+1]) * (vet[i] - vet[i+1])) / (tam - 1);
    }
    return varia;
}

int main(){
    int idade, n, i, idadef = 0, alturam = 0;
    char sexo;
    float var, altura;
    scanf("%d", &n);
    float alturas[n];
    for(i=0;i<n;i++){
        printf("pessoa %d\n", i+1);
        puts("Qual sua altura");
        scanf(" %f", &altura);
        puts("Qual sua idade");
        scanf(" %d", &idade);
        do{
            puts("Qual seu sexo | m ou f |");
            scanf(" %c", &sexo);
        }while(sexo != 'm' && sexo!= 'f');

        if(sexo == 'm'){
            if(altura > 1.8){
                alturam += 1;
            }
        }

        else{

            if(idade >= 20 && idade <=35){
                idadef += 1;
            }
        }
        alturas[i] = altura;
    }
    var = variancia(alturas, n);

    printf("número de mulheres com idade entre 20 e 35 anos : %d\n",idadef);
    printf("número de homens com altura maior que 1,80m : %d\n", alturam);
    printf("variancia = %f", var);
    return 0;
}