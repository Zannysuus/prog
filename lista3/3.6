#include <stdio.h>

int maiores(int n, int * vet, int x){
    int i, num=0;
    for(i=0;i<=n;i++){
        if(vet[i]>x){
            num += 1;
        }
    }
    return num;
}

int main(void) {
    int laele,tam,x,vetor[] = {5,6,3,1,45,67,22,12};
    tam = sizeof(vetor)/sizeof(vetor[0]);
    scanf("%d", &x);
    laele = maiores(tam,vetor,x);
    printf("%d",laele);
    return 0;
}
