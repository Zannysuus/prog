#include <stdio.h>

float media(int n, float *v){
    int i;
    float med, soma = 0;
    for(i=0;i<n;i++){
        soma += v[i];
    }
    med = soma / n;
    return med;
}

int main(){
    int tam;
    float m, vetor[] = {1,2,3,4,5};
    tam = sizeof(vetor)/sizeof(vetor[0]);
    m = media(tam, vetor);
    printf("%.2f", m);
    return 0;
}