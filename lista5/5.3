#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int contabilizar(char* p, char l){
    int i, cont=0;
    for(i=0;i<strlen(p);i++){
        if(p[i]==l){
            cont++;
        }
    }
    return cont;
}

int main(){
    char letra, palavra[20];
    int n;
    printf("digite a palavra: ");
    scanf(" %s", palavra);
    printf("digite a letra que quer contabilizar: ");
    scanf(" %c", &letra);
    n = contabilizar(palavra, letra);
    printf("%d", n);
    return 0;
}